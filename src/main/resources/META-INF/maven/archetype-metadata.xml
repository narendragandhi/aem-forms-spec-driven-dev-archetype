<?xml version="1.0" encoding="UTF-8"?>
<archetype-descriptor xsi:schemaLocation="http://maven.apache.org/plugins/maven-archetype-plugin/archetype-descriptor/1.0.0 http://maven.apache.org/xsd/archetype-descriptor-1.0.0.xsd" name="aem-forms-bmad-archetype"
    xmlns="http://maven.apache.org/plugins/maven-archetype-plugin/archetype-descriptor/1.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <requiredProperties>
        <requiredProperty key="formsVersion">
            <defaultValue>afaacs</defaultValue>
            <validationRegex>afaacs|6\.5</validationRegex>
        </requiredProperty>
        <requiredProperty key="includeSpecDrivenExamples">
            <defaultValue>true</defaultValue>
            <validationRegex>true|false</validationRegex>
        </requiredProperty>
        <requiredProperty key="includeShowcaseExamples">
            <defaultValue>true</defaultValue>
            <validationRegex>true|false</validationRegex>
        </requiredProperty>
        <requiredProperty key="appName">
            <defaultValue>MyFormsApp</defaultValue>
        </requiredProperty>
    </requiredProperties>
    <fileSets>
        <!-- Filtered text files (POMs, XMLs, Java, JS) -->
        <fileSet filtered="true">
            <directory></directory>
            <includes>
                <include>**/pom.xml</include>
                <include>**/*.xml</include>
            </includes>
            <excludes>
                <exclude>ui.frontend/node_modules/**</exclude>
            </excludes>
        </fileSet>
        <fileSet filtered="true" packaged="true">
            <directory>core/src/main/java</directory>
            <includes>
                <include>**/*.java</include>
            </includes>
        </fileSet>
        <fileSet filtered="true">
            <directory>ui.frontend.react.forms.af/src/main/webpack/components</directory>
            <includes>
                <include>**/*.js</include>
            </includes>
        </fileSet>

        <!-- Unfiltered files (HTL, CSS, JS, Binary) -->
        <fileSet filtered="false">
            <directory>ui.apps</directory>
            <includes>
                <include>**/*.html</include>
                <include>**/*.js</include>
                <include>**/*.css</include>
                <include>**/*.txt</include>
                <include>**/*.png</include>
                <include>**/*.ico</include>
                <include>**/*.woff</include>
                <include>**/*.woff2</include>
                <include>**/*.ttf</include>
                <include>**/*.otf</include>
                <include>**/*.eot</include>
            </includes>
        </fileSet>
        <fileSet filtered="false">
            <directory>ui.content</directory>
            <includes>
                <include>**/*.png</include>
                <include>**/*.jpg</include>
                <include>**/*.jpeg</include>
                <include>**/*.gif</include>
                <include>**/*.svg</include>
            </includes>
        </fileSet>
        <fileSet filtered="false">
            <directory>ui.frontend</directory>
            <includes>
                <include>**/*</include>
            </includes>
            <excludes>
                <exclude>pom.xml</exclude>
                <exclude>node_modules/**</exclude>
            </excludes>
        </fileSet>
        <fileSet filtered="false">
            <directory>core</directory>
            <includes>
                <include>**/bnd.bnd</include>
            </includes>
        </fileSet>
        <fileSet filtered="false">
            <directory>specs</directory>
            <includes>
                <include>**/*.json</include>
            </includes>
        </fileSet>
        <fileSet filtered="false">
            <directory>bmad</directory>
            <includes>
                <include>**/*.md</include>
            </includes>
        </fileSet>
        <fileSet filtered="false">
            <directory>dispatcher</directory>
            <includes>
                <include>**/*</include>
            </includes>
            <excludes>
                <exclude>pom.xml</exclude>
            </excludes>
        </fileSet>
        <fileSet filtered="true">
            <directory>it.tests</directory>
            <includes>
                <include>**/*</include>
            </includes>
            <excludes>
                <exclude>pom.xml</exclude>
            </excludes>
        </fileSet>
        <fileSet filtered="false">
            <directory>ui.tests</directory>
            <includes>
                <include>**/*</include>
            </includes>
            <excludes>
                <exclude>pom.xml</exclude>
            </excludes>
        </fileSet>
        <fileSet filtered="true">
            <directory>ui.apps.structure</directory>
            <includes>
                <include>pom.xml</include>
            </includes>
        </fileSet>
        <fileSet filtered="true">
            <directory>ui.apps.structure/src/main/content/META-INF/vault</directory>
            <includes>
                <include>filter.xml</include>
            </includes>
        </fileSet>
    </fileSets>
</archetype-descriptor>
